# T.G.winG 웹 — 환경변수 예시
#
# ⚠️ 로컬 개발(린 스캐폴딩 단계)은 비밀키 0개로 동작합니다.
#    git clone → npm install → npm run dev 면 끝. 이 파일을 복사할 필요도 없습니다.
#
# 아래 값들은 *배포(Vercel·쿠러그)* 또는 DB·인증·스토리지를 붙이는 단계에서만 필요합니다.
# (DECISIONS §17 — 기여자 온보딩: 비밀키 0개 로컬 실행)
#
# 실제 비밀키는 절대 커밋하지 마세요. 이 .env.example 만 커밋합니다.

# --- DB (Postgres) — 스캐폴딩 '중간' 범위 이상에서 사용 ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/tgwing

# --- 인증 (Auth.js + GitHub OAuth) — Private 기능 단계에서 ---
# AUTH_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_DEV_BYPASS=true   # 로컬에서 가짜 멤버 세션 (OAuth 앱 없이)

# --- 파일 저장 (Cloudflare R2, S3 호환) — 스터디 자료 단계에서 ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
